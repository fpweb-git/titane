{
  "name": "titane_engine",
  "version": "0.2.1",
  "description": "Typescript game engine",
  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "core:dev": "npm run dev -w @titane/core",
    "editor:dev": "npm run dev -w @titane/editor",
    "bump:patch": "npm version patch --workspaces --include-workspace-root --no-git-tag-version",
    "bump:minor": "npm version minor --workspaces --include-workspace-root --no-git-tag-version",
    "bump:major": "npm version major --workspaces --include-workspace-root --no-git-tag-version"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0"
  }
}
